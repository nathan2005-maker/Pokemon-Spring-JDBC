package com.pokemon.pokemonrpg.model;

import java.util.EnumSet;

public enum Types {
    GRASS, FIRE, WATER, BUG, NORMAL, POISON, ELECTRIC, GROUND, 
    FLYING, ICE, GHOST, PSYCHIC, ROCK, DRAGON, FIGHTING;

    private EnumSet<Types> fraquezas;
    private EnumSet<Types> vantagens;

    // Método para configurar as relações
    public void definirInteracoes(EnumSet<Types> fraquezas, EnumSet<Types> vantagens) {
        this.fraquezas = fraquezas;
        this.vantagens = vantagens;
    }
    
    static {
    	
    	FIRE.definirInteracoes(
    			EnumSet.of(Types.WATER)
    			EnumSet.of(Types.GRASS,
    					Types.ICE));
    	
    	
    }

 }