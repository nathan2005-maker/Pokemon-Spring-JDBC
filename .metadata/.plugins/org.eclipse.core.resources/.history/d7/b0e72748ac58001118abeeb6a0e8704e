package com.pokemon.pokemonrpg.service;

import com.pokemon.pokemonrpg.model.Pokemon;
import com.pokemon.pokemonrpg.model.Types;
import com.pokemon.pokemonrpg.model.DamageCategory;
import org.springframework.stereotype.Service;

@Service
public class CombatActionImpl implements CombatAction {

    @Override
    public int executeAttack(Pokemon atacante, Pokemon defensor, int movePower, Types moveType, DamageCategory category) {
        return executeAttack(atacante, defensor, movePower, moveType, false, category);
    }

    @Override
    public int executeAttack(Pokemon atacante, Pokemon defensor, int movePower, Types moveType, boolean isCritical, DamageCategory category) {
        // 1. Se for status, não causa dano direto (por enquanto)
        if (category == DamageCategory.STATUS) return 0;

        // 2. Escolha dos atributos baseados na categoria
        double ataqueBase = (category == DamageCategory.PHYSICAL) ? atacante.getAttack() : atacante.getSpAttack();
        double defesaBase = (category == DamageCategory.PHYSICAL) ? defensor.getDefense() : defensor.getSpDefense();

        // 3. Conversão de tipo do defensor
        Types tipoDefensor = Types.valueOf(defensor.getType1().trim().toUpperCase());
        double multiplicador = moveType.calcularEfetividadeContra(tipoDefensor);

        // 4. Cálculo do dano
        double dano = (movePower * (ataqueBase / defesaBase)) * multiplicador;

        if (isCritical) {
            dano *= 1.5;
        }

        return (int) dano;
    }
}